# MySQL
MYSQL_DATABASE=study2026
MYSQL_USER=study
MYSQL_PASSWORD=study
MYSQL_ROOT_PASSWORD=root

# Backend
DATABASE_URL=mysql+pymysql://study:study@mysql:3306/study2026
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://study2026.bssm.dev/api/auth/google/callback

# 로그인 허용 이메일 도메인 (콤마 구분)
ALLOWED_EMAIL_DOMAINS=bssm.hs.kr
# 개인 계정이지만 admin 권한을 부여할 이메일 화이트리스트 (콤마 구분)
ADMIN_EMAILS=startea0716@gmail.com

FRONTEND_URL=https://study2026.bssm.dev

# SolAPI (참가 신청 승인 시 문자 발송)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=

# 참가 신청 기간 (비워두면 해당 방향 제한 없음, 형식: 2026-07-20T00:00:00)
APPLICATION_OPENS_AT=
APPLICATION_CLOSES_AT=

# 디스코드 웹훅 (발표 날짜 오픈/신청 알림, 비워두면 알림 안 보냄)
# 디스코드 채널 설정 > 연동 > 웹훅 > 새 웹훅 만들기 > URL 복사
DISCORD_WEBHOOK_URL=

# 디스코드 봇 — 발표 신청 시 서버 이벤트(Scheduled Event)를 음성채널에 자동 등록
# 토큰은 비밀값이라 여기(.env)에서만 관리. 길드ID/채널ID/발표시간/진행시간은
# 여기 값을 최초 기본값으로 쓰고, 이후 관리자 페이지(/admin > 설정 > 디스코드 발표 이벤트)에서 덮어쓸 수 있음
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
# 발표 고정 시간 (HH:MM, 24시간제)과 진행 시간(분) — 날짜만 입력받으므로 자동으로 붙임
PRESENTATION_TIME=21:00
PRESENTATION_DURATION_MINUTES=60
